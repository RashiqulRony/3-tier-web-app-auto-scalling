    "monitoring_commands": {
      "value": "# Monitor Frontend Auto Scaling Group\r\naws autoscaling describe-auto-scaling-groups --auto-scaling-group-names bmi-frontend-asg-20260612053213823900000007 --region ap-south-1\r\n    \r\n# Monitor Frontend Target Health\r\naws elbv2 describe-target-health --target-group-arn arn:aws:elasticloadbalancing:ap-south-1:388779989543:targetgroup/bmife-20260612045635971400000013/830aeee50e6ad69a --region ap-south-1\r\n    \r\n# Monitor Backend Target Health\r\naws elbv2 describe-target-health --target-group-arn arn:aws:elasticloadbalancing:ap-south-1:388779989543:targetgroup/bmibe-20260612045635971400000012/db898dcef69b2418 --region ap-south-1\r\n    \r\n# Connect to Backend Instance via SSM (replace INSTANCE_ID)\r\naws ssm start-session --target INSTANCE_ID --region ap-south-1\r\n    \r\n# View ASG Activity\r\naws autoscaling describe-scaling-activities --auto-scaling-group-name bmi-frontend-asg-20260612053213823900000007 --max-records 10 --region ap-south-1\r\n",
      "type": "string"
    },
    "quick_start_guide": {
      "value": "╔════════════════════════════════════════════════════════════════╗\r\n║          BMI Auto-Scaling Application - Deployed! 🎉           ║\r\n╚════════════════════════════════════════════════════════════════╝\r\n    \r\n📱 Application URL:\r\n   http://bmife-2026061204563597090000000f-8667097.ap-south-1.elb.amazonaws.com\r\n    \r\n🔍 Monitoring:\r\n   • Frontend ASG: bmi-frontend-asg-20260612053213823900000007\r\n   • Backend Instances: 2 fixed instances\r\n   • Database: Aurora Serverless v2 (0.5-1 ACU)\r\n    \r\n📊 Load Testing (Demonstrate Auto-Scaling):\r\n   cd ../load-test\r\n   ./quick-test.sh http://bmife-2026061204563597090000000f-8667097.ap-south-1.elb.amazonaws.com\r\n    \r\n🔐 SSH Access (via SSM):\r\n   aws ssm start-session --target \u003cinstance-id\u003e --region ap-south-1\r\n    \r\n⚠️  IMPORTANT - Cleanup After Demo:\r\n   terraform destroy -auto-approve\r\n    \r\n💰 Current Cost: ~$0.20-$0.40/hour\r\n",
      "type": "string"
    },
